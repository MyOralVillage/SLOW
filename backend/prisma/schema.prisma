generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FileStorage {
  disk
}

enum UserRole {
  owner
  admin
  vip
  specialist
  member
  none
}

enum UserStatus {
  active
  invited
  disabled
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password_hash String?
  role       UserRole    @default(member)
  status     UserStatus  @default(active)
  country    String?
  why_interested String?
  avatar_name String?
  avatar_storage_key String?
  email_verified Boolean  @default(false)
  email_verification_token String? @unique
  email_verification_expires DateTime?
  password_reset_token String? @unique
  password_reset_expires DateTime?
  whatsapp_phone String?
  biodata    String?
  social_handles String?
  permission_grants String[] @default([])
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  sessions   Session[]
  resources  Resource[]  @relation("UploadedResources")
  comments   Comment[]
  messagesSent     Message[] @relation("MessagesSent")
  messagesReceived Message[] @relation("MessagesReceived")
  conversationParticipants ConversationParticipant[]
  conversationMessagesSent ConversationMessage[] @relation("ConversationMessagesSent")
  notifications   Notification[]

  @@index([role])
  @@index([status])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  body       String
  data_json  Json?
  is_read    Boolean  @default(false)
  read_at    DateTime?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([user_id, is_read, created_at])
}

model Conversation {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  participants ConversationParticipant[]
  messages     ConversationMessage[]
}

model ConversationParticipant {
  id              String   @id @default(uuid())
  created_at      DateTime @default(now())
  last_read_at    DateTime?
  conversation_id String
  user_id         String

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@index([user_id, created_at])
}

model ConversationMessage {
  id              String   @id @default(uuid())
  body            String
  created_at      DateTime @default(now())
  read_at         DateTime?
  conversation_id String
  sender_id       String
  resource_id     String?

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender       User         @relation("ConversationMessagesSent", fields: [sender_id], references: [id], onDelete: Cascade)
  resource     Resource?    @relation(fields: [resource_id], references: [id], onDelete: SetNull)

  @@index([conversation_id, created_at])
  @@index([sender_id, created_at])
  @@index([resource_id])
}

model Session {
  id         String   @id @default(uuid())
  token      String   @unique
  created_at DateTime @default(now())
  expires_at DateTime

  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model Resource {
  id                String      @id @default(uuid())
  title             String
  description       String
  country           String
  category          String
  product_detail    String?
  cross_cutting_category String?
  institution       String?
  type              String
  keywords          String[]
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  uploaded_by       String?
  uploadedBy        User?       @relation("UploadedResources", fields: [uploaded_by], references: [id], onDelete: SetNull)
  comments          Comment[]

  file_storage      FileStorage @default(disk)
  storage_key       String?
  file_path         String?
  external_url      String?
  mime_type         String?
  size_bytes        BigInt?
  original_filename String?
  sha256            String?
  file_bytes        Bytes?
  conversationMessages ConversationMessage[]

  @@index([country])
  @@index([category])
  @@index([product_detail])
  @@index([cross_cutting_category])
  @@index([institution])
  @@index([type])
  @@index([uploaded_by])
}

model Comment {
  id         String   @id @default(uuid())
  body       String
  created_at DateTime @default(now())

  resource_id String
  resource    Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([resource_id, created_at])
  @@index([user_id])
}

model Message {
  id         String   @id @default(uuid())
  body       String
  created_at DateTime @default(now())
  read_at    DateTime?

  from_user_id String
  to_user_id   String
  fromUser     User @relation("MessagesSent", fields: [from_user_id], references: [id], onDelete: Cascade)
  toUser       User @relation("MessagesReceived", fields: [to_user_id], references: [id], onDelete: Cascade)

  @@index([to_user_id, created_at])
  @@index([from_user_id, created_at])
}
