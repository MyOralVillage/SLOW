DATABASE_URL="postgresql://slow:slow_password@localhost:5433/slow_oim?schema=public"
PORT=3001
API_KEY="change-me"
OWNER_EMAILS="brett@example.com"
ADMIN_EMAILS="brett@example.com"
SESSION_TTL_DAYS=14
# Local upload directory (defaults to backend/uploads). In production, point this to a persistent volume mount.
UPLOAD_DIR="../uploads"
CORS_ORIGIN="http://127.0.0.1:8080"
# Public frontend URL used in verification + password reset links.
FRONTEND_URL="http://127.0.0.1:8080"
# Backward-compatible fallback if FRONTEND_URL is unset.
WEB_APP_URL="http://127.0.0.1:8080"
# Public backend base URL for deployed clients / docs.
BACKEND_URL="http://127.0.0.1:3001"
# Outbound email.
# Production:
# EMAIL_PROVIDER="resend" with RESEND_API_KEY
# EMAIL_PROVIDER="smtp" with SMTP_*
# Shared sender:
# EMAIL_FROM="SLOW <no-reply@example.com>"
# Local preview only:
# EMAIL_PROVIDER="log"
# Resend: https://resend.com — use onboarding@resend.dev until you verify a domain, then set EMAIL_FROM or RESEND_FROM.
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_..."
# RESEND_FROM="SLOW <onboarding@resend.dev>"
# SMTP (alternative to Resend)
# EMAIL_PROVIDER="smtp"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="SLOW <no-reply@example.com>"
