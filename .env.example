# BookStack app settings
APP_URL=http://localhost:6875
APP_KEY=base64:replace-with-generated-bookstack-key

# Database settings
DB_HOST=bookstack_db
DB_PORT=3306
DB_DATABASE=bookstack
DB_USERNAME=bookstack
DB_PASSWORD=bookstack_password

# BookStack API tokens for smoke tests / integrations
BOOKSTACK_API_TOKEN_ID=replace_me
BOOKSTACK_API_TOKEN_SECRET=replace_me
